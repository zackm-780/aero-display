OPEN_SKY_BASE_URL=https://opensky-network.org/api

# OAuth2 client credentials for OpenSky.
# Create an API client in your OpenSky account and paste the client ID/secret here.
# These are required; username/password auth is no longer supported.
OPEN_SKY_CLIENT_ID=
OPEN_SKY_CLIENT_SECRET=

# Default home center ICAO for the radar/board
DEFAULT_CENTER_ICAO=KSFO

# Optional overrides for data and frontend paths; normally not required.
# DATA_DIR=/absolute/path/to/backend/data
# FRONTEND_DIR=/absolute/path/to/frontend
